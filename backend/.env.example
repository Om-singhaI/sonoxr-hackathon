# Copy this file to ".env" and fill in your key.  NEVER commit your real .env.
#
# Anthropic API key for the narration stage (stage 5).
# Without it, narration still works via a templated, non-LLM fallback — but the
# REAL_AI narration (the demo headline) needs this set.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the narration model (default: claude-sonnet-4-6).
# NARRATION_MODEL=claude-sonnet-4-6

# Optional: path to an UltrasODM wrapper script to enable the 2D-sweep STRETCH
# reconstruction path. Leave unset — the demo never depends on it.
# ULTRASODM_RUNNER=/path/to/ultrasodm_wrapper.sh
