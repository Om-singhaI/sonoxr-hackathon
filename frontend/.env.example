# SonoXR — server-side API keys for the Patient Viewer AI panel.
# These are read ONLY by the Vercel serverless functions in /api (never shipped to
# the browser). Set them in the Vercel project (Settings → Environment Variables),
# or in a local .env for `vercel dev`. Until they are set, the app falls back to the
# built-in static narration / Web Speech voice and the mic button is hidden.

# Claude — generates the grounded AI analysis (api/analyze.ts). Get one at
# https://console.anthropic.com  → uses model claude-opus-4-8.
ANTHROPIC_API_KEY=

# Deepgram — text-to-speech (api/tts.ts) and speech-to-text (api/stt.ts).
# Get one at https://console.deepgram.com
DEEPGRAM_API_KEY=
